# ===== AWS (DynamoDB / SES) =====
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_REGION defaults to ap-northeast-1

# ===== Stripe =====
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ===== Auth (NextAuth) =====
NEXTAUTH_URL=http://localhost:3000

# ===== Admin =====
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
ADMIN_TOTP_SECRET=
# true にすると TOTP 必須。秘密鍵未設定ならログインを拒否（フェイルクローズ）。本番は true 推奨。
ADMIN_TOTP_REQUIRED=

# ===== Passkey / WebAuthn (optional) =====
# 未設定時はリクエスト元のホスト/オリジンから自動導出される。
# 本番で固定したい場合のみ設定（例: RP_ID=www.sikocoffee.com / ORIGIN=https://www.sikocoffee.com）
WEBAUTHN_RP_ID=
WEBAUTHN_RP_NAME=
WEBAUTHN_ORIGIN=

# ===== Tokens / Secrets =====
ORDER_TOKEN_SECRET=
CRON_SECRET=
REVALIDATE_SECRET=

# ===== Instagram =====
INSTAGRAM_ACCESS_TOKEN=

# ===== Email =====
MAIL_FROM=noreply@sikocoffee.com

# ===== Site =====
SITE_URL=http://localhost:3000

# ===== Analytics (optional) =====
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ===== Slack (optional) =====
SLACK_WEBHOOK_URL=

# ===== Sentry (optional) =====
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
